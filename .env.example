# Copy to ".env" — never commit the real .env.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=books_api
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
DB_SSL=false   # Set to true for Aiven / managed cloud databases

# Generate with: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=change-me-to-a-long-random-string-please-do-not-commit
JWT_TTL=3600
JWT_ISSUER=books-api

# Comma-separated origins allowed by CORS. Leave blank to fall back to '*'.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Rate limiting on /auth/login: max attempts per WINDOW_SECONDS per IP.
LOGIN_RATE_LIMIT=5
LOGIN_WINDOW_SECONDS=60

APP_DEBUG=false
